# Optional: a logged-in Bilibili cookie used by the server proxy.
# When empty, the app still works in anonymous mode, but comment results may be incomplete.
BILIBILI_COOKIE=

# Optional: Upstash Redis for online user count tracking.
# Get free credentials at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
